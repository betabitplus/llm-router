# shellcheck shell=bash

# shellcheck disable=SC1091
source .venv/bin/activate

# Repo-scoped local secrets for all worktrees.
# The `LLM_ROUTER_` prefix mirrors `[tool.py_lib_starter].env_prefix`.
export LLM_ROUTER_ENV_FILE="${LLM_ROUTER_ENV_FILE:-$HOME/researcher-local/.env}"
dotenv_if_exists "$LLM_ROUTER_ENV_FILE"

# Optional per-worktree direnv override.
source_env_if_exists .envrc.local

export PYTHONPATH="$PWD/src:$PWD"
